# .env.example
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.

# ── Anthropic ─────────────────────────────────────────────────────────────────
# https://console.anthropic.com → API Keys

ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Admin dashboard ───────────────────────────────────────────────────────────
# Arbitrary secret passed in the x-admin-secret header to access /dashboard.

ADMIN_SECRET=change-me-to-a-long-random-string

# ── Gmail SMTP (visitor-email notifications) ──────────────────────────────────
# 1. Enable 2-Step Verification on your Google account.
# 2. myaccount.google.com → Security → App Passwords → create "Technocure Bot".
# 3. Paste the 16-character password (no spaces) into GMAIL_APP_PASSWORD.
# If these are omitted, notifications are silently skipped.

GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
