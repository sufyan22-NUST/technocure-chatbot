# .env.example
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── OpenAI ────────────────────────────────────────────────────────────────────
# https://platform.openai.com/api-keys

OPENAI_API_KEY=sk-...

# ── Admin dashboard ───────────────────────────────────────────────────────────
# Arbitrary secret passed in the x-admin-secret header to access /dashboard.
# Replace with a proper auth solution (Supabase Auth, NextAuth) before production.

ADMIN_SECRET=change-me-to-a-long-random-string
